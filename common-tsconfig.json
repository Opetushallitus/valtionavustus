{
  "compilerOptions": {
    "moduleResolution": "bundler",
    "strict": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "target": "es6",
    "module": "esnext",
    "lib": ["dom", "es2021"],
    "rootDir": ".",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "jsx": "react",
    "sourceMap": true
  }
}
